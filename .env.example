NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# Optional: set GEOTIFF_URL to read the GeoTIFF via HTTP range requests
# instead of from the local data/ directory. Use for deployment (R2, S3, etc.)
# GEOTIFF_URL=https://your-bucket.r2.dev/GHS_POP_E2025_GLOBE_R2023A_4326_30ss_V1_0.tif

# Optional: set TRAVEL_TIME_URL to read precomputed travel-time JSON files
# from a remote bucket (R2/S3) instead of the local data/travel-time/ dir.
# TRAVEL_TIME_URL=https://your-bucket.r2.dev/travel-time

# Set to "true" to include the /migrate admin dashboard and the
# /api/travel-time/compute + /api/travel-time/migrate endpoints in the build.
# Without this, those files are not compiled at all (next.config.ts pageExtensions).
# Required for the data-recompute workflow; leave unset for production builds.
# NEXT_PUBLIC_DEV_MODE=true

# TravelTime API credentials (only needed when running the admin compute flow).
# TRAVELTIME_APP_ID=your_app_id
# TRAVELTIME_API_KEY=your_api_key
