# Pop Squared uses Infisical for secrets, not a .env file.
#
# This file is kept only as documentation of which env vars the codebase
# expects. The actual values live in Infisical:
#   ya-tools  →  Development / Production  →  /pop-squared
#
# `npm run dev` runs through `infisical run` and pulls from Infisical
# automatically. Don't create a `.env.local` — the repo deliberately
# forbids on-disk secrets after the 2026-05 migration.
#
# To run anything else with secrets injected:
#   infisical run --env=dev --path=/pop-squared -- <command>
# e.g. for the R2 deploy scripts:
#   infisical run --env=dev --path=/pop-squared -- bash scripts/deploy-r2.sh

# Public — Mapbox base map token (browser-exposed, URL-restrict it in Mapbox).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Required — R2 URLs for the world population GeoTIFF and travel-time data prefix.
GEOTIFF_URL=
TRAVEL_TIME_URL=

# Dev-mode flag — set to "true" only in Development env. Gates the /migrate
# admin dashboard and the recompute API routes (next.config.ts pageExtensions
# also excludes .dev.ts files when this is unset). MUST be unset/false in Production.
NEXT_PUBLIC_DEV_MODE=

# TravelTime API credentials — only needed for the /migrate recompute flow.
TRAVELTIME_APP_ID=
TRAVELTIME_API_KEY=

# R2 deploy credentials — only needed for scripts/deploy-r2.sh and
# scripts/deploy-travel-time-r2.sh. YA Cloudflare account.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_BUCKET=
